# Create the .gitignore file with all rules
@"
# Dependencies
node_modules/
package-lock.json
yarn.lock

# Environment files - NEVER COMMIT THESE!
.env
.env.local
.env.*.local
*.env
*.env.*
!.env.example

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE files
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
.next/
out/

# Cache files
.cache/
*.cache

# Testing
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
*.bak
"@ | Out-File -FilePath .gitignore -Encoding utf8

# Verify it was created
Get-Content .gitignore